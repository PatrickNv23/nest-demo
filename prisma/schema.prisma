generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model comment_attachments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  comment_id String    @db.Uuid
  file_name  String    @db.VarChar(255)
  file_url   String
  file_type  String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  is_active  Boolean   @default(false)
  comments   comments  @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attachment_comment")
}

model comments {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id           String                @db.Uuid
  user_id             String                @db.Uuid
  content             String
  is_internal         Boolean?              @default(false)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  created_by          String?               @db.Uuid
  updated_by          String?               @db.Uuid
  is_active           Boolean               @default(false)
  comment_attachments comment_attachments[]
}

model departments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid
  is_active   Boolean   @default(false)
  users       users[]
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  message    String
  is_read    Boolean?  @default(false)
  type       String    @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  is_active  Boolean   @default(false)
}

model roles {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  is_active  Boolean   @default(false)
  users      users[]
}

model ticket_status_history {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id          String    @db.Uuid
  status_before      String?   @db.VarChar(50)
  status_after       String    @db.VarChar(50)
  changed_by_user_id String    @db.Uuid
  change_reason      String?
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  created_by         String?   @db.Uuid
  updated_by         String?   @db.Uuid
  is_active          Boolean   @default(false)
  tickets            tickets   @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_ticket")
}

model ticket_statuses {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique @db.VarChar(50)
  step_order Int       @unique
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  is_active  Boolean   @default(false)
  tickets    tickets[]
}

model ticket_types {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  is_active  Boolean   @default(false)
  tickets    tickets[]
}

model tickets {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String                  @db.VarChar(255)
  description           String
  status_id             String                  @db.Uuid
  priority              String                  @db.VarChar(20)
  type_id               String                  @db.Uuid
  creator_user_id       String                  @db.Uuid
  assigned_agent_id     String?                 @db.Uuid
  department_id         String?                 @db.Uuid
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  created_by            String?                 @db.Uuid
  updated_by            String?                 @db.Uuid
  is_active             Boolean                 @default(false)
  ticket_status_history ticket_status_history[]
  ticket_statuses       ticket_statuses         @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_status")
  ticket_types          ticket_types            @relation(fields: [type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_type")
}

model users {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String       @unique @db.VarChar(50)
  email         String       @unique @db.VarChar(100)
  phone_number  String?      @db.VarChar(20)
  password_hash String       @db.VarChar(255)
  role_id       String       @db.Uuid
  department_id String?      @db.Uuid
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?    @default(now()) @db.Timestamptz(6)
  created_by    String?      @db.Uuid
  updated_by    String?      @db.Uuid
  is_active     Boolean      @default(false)
  departments   departments? @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_department")
  roles         roles        @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_role")
}
